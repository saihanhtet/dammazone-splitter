# Optional: Gemini API key for the main (Bun) process.
# You can also set the key in the in-app Settings screen (stored under app user data).
GEMINI_API_KEY=

# Alternative env name supported by @google/genai:
# GOOGLE_API_KEY=

# Optional: override default model (default: gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash

# Optional: @google/genai API version for AI Studio. Leave unset for SDK default (v1beta).
# Setting GEMINI_API_VERSION=v1 can cause HTTP 404 for some models.
# GEMINI_API_VERSION=
